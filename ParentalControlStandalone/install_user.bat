@echo off
echo ============================================
echo   Установка Родительского контроля
echo   (для текущего пользователя)
echo ============================================
echo.

echo Установка для пользователя: %USERNAME%
echo Папка установки: %LOCALAPPDATA%\ParentalControl
echo.

echo [1/2] Установка программы...
ParentalControl.exe install-user

if errorlevel 1 (
    echo.
    echo ОШИБКА установки!
    echo Убедитесь, что файл ParentalControl.exe находится в этой же папке.
    pause
    exit /b 1
)

echo.
echo [2/2] Настройка завершена!
echo.
echo ============================================
echo   Установка завершена!
echo ============================================
echo.
echo На рабочем столе созданы ярлыки:
echo   - "Родительский контроль - Админ" (настройка)
echo   - "Родительский контроль - Защита" (вкл/выкл)
echo.
echo Фоновый процесс запущен и добавлен в автозагрузку.
echo.
echo ЧТО ДЕЛАТЬ ДАЛЬШЕ:
echo 1. Откройте "Родительский контроль - Админ"
echo 2. Установите пароль администратора
echo 3. Добавьте разрешённые временные интервалы
echo.
echo Для выключения защиты используйте ярлык "Защита".
echo Для удаления: запустите uninstall_user.bat
echo.
pause
